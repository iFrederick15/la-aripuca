---
import Layout from "../layouts/Layout.astro";

const fotos = [
  {
    src: "/images/aripuca-compromiso.jpeg",
    alt: "La Aripuca",
    categoria: "arquitectura",
    titulo: "La Aripuca",
    descripcion:
      "Estructura imponente de más de 500.000 kg de madera recuperada.",
    tamaño: "grande",
  },
  {
    src: "/images/guaranies.jpg",
    alt: "Guaranies",
    categoria: "guaranies",
    titulo: "Guaranies haciendo un show en La Aripuca.",
    descripcion: "",
    tamaño: "ancho",
  },
  {
    src: "/images/las-tacuaras.jpg",
    alt: "Las Tacuaras",
    categoria: "arquitectura",
    titulo: "Las Tacuaras",
    descripcion: "",
    tamaño: "grande",
  },

  {
    src: "/images/ninhos-guaranies.JPG",
    alt: "Niños guaranies cantando",
    categoria: "guaranies",
    titulo: "Niños guaranies cantando",
    descripcion:
      "Niños compartiendo su cultura y talento a los visitantes de La Aripuca.",
    tamaño: "",
  },

  {
    src: "/images/cucurucho.jpg",
    alt: "Helados con sabores únicos vendidos en La Aripuca.",
    categoria: "gastronomia",
    titulo: "Helado de Rosella",
    descripcion: "Helado de Rosella servido en cucurucho",
    tamaño: "alto",
  },
  {
    src: "/images/tiro-flecha.jpg",
    alt: "Turistas divirtiendose jugando al tiro de flechas.",
    categoria: "ustedes",
    titulo: "Turista jugando al tiro de flecha",
    descripcion: "",
    tamaño: "",
  },
  {
    src: "/images/aripuca-estacionamiento.jpeg",
    alt: "Estacionamiento de La Aripuca",
    categoria: "arquitectura",
    titulo: "Estacionamiento de La Aripuca",
    descripcion: "Estacionamiento sin cargo exclusivo para ustedes.",
    tamaño: "grande",
  },
  {
    src: "/images/las-termitas.jpg",
    alt: "Restaurante Las Termitas ubicado dentro del predio.",
    categoria: "arquitectura",
    titulo: "Restaurante Las Termitas ubicado dentro del predio La Aripuca",
    descripcion: "Restaurante con gran variedad de platos exquisitos.",
    tamaño: "grande",
  },
  {
    src: "/images/tacuru.jpg",
    alt: "El Tacurú.",
    categoria: "arquitectura",
    titulo: "El Tacurú",
    descripcion:
      "El edificio fue construido con más de 500 toneladas de piedras misioneras como basalto negro, jaspe rojo, ojo de sapo, basalto oxidado, arenisca, canto rodado y amatista, reflejando la diversidad mineral de la región.",
    tamaño: "grande",
  },
  {
    src: "/images/yatei-fuera.jpg",
    alt: "El Yateí.",
    categoria: "arquitectura",
    titulo: "El Yateí",
    descripcion:
      "Este espacio refleja la arquitectura tradicional de los agricultores en Misiones, con su característico techo a dos aguas, galería frontal y base elevada para protegerse de la humedad y los animales.",
    tamaño: "grande",
  },

  {
    src: "/images/maderas-dentro-de-la-aripuca.jpg",
    alt: "Maderas dentro de La Aripuca.",
    categoria: "arquitectura",
    titulo: "Algunos nombres de los troncos recuperados.",
    descripcion: "",
    tamaño: "normal",
  },
  {
    src: "/images/sendero-al-entrar-a-la-aripuca.jpeg",
    alt: "Sendero de ingreso a La Aripuca.",
    categoria: "arquitectura",
    titulo: "Sendero de Ingreso",
    descripcion:
      "El camino de entrada a La Aripuca, rodeado de la exuberante selva misionera.",
    tamaño: "grande",
  },
  {
    src: "/images/asado.jpeg",
    alt: "Asado misionero en La Aripuca.",
    categoria: "gastronomia",
    titulo: "Asado Criollo",
    descripcion:
      "El tradicional asado criollo preparado con las mejores carnes, una delicia infaltable.",
    tamaño: "grande",
  },
  {
    src: "/images/costillar.jpeg",
    alt: "Costillar a la cruz en La Aripuca.",
    categoria: "gastronomia",
    titulo: "Costillar a la Cruz",
    descripcion:
      "Cocción lenta a la cruz, técnica criolla que logra la carne más tierna y sabrosa.",
    tamaño: "ancho",
  },
  {
    src: "/images/chipaguazu.jpeg",
    alt: "Chipaguazú, receta guaraní tradicional.",
    categoria: "gastronomia",
    titulo: "Chipaguazú",
    descripcion:
      "Tradicional receta guaraní a base de choclo y queso, cocida en horno de barro.",
    tamaño: "alto",
  },
  {
    src: "/images/pasapalos.jpeg",
    alt: "Pasapalos típicos de la región.",
    categoria: "gastronomia",
    titulo: "Pasapalos",
    descripcion:
      "Bocados típicos de la región para comenzar la experiencia gastronómica.",
    tamaño: "",
  },
  {
    src: "/images/sandwiches.jpeg",
    alt: "Sándwiches en La Aripuca.",
    categoria: "gastronomia",
    titulo: "Sándwiches Regionales",
    descripcion:
      "Elaborados con ingredientes frescos y sabores regionales únicos.",
    tamaño: "normal",
  },
];

const categorias = [
  "todo",
  "arquitectura",
  "gastronomia",
  "guaranies",
  "ustedes",
];

const categoriasLabel: Record<string, string> = {
  todo: "Todo",
  arquitectura: "Arquitectura",
  guaranies: "Guaranies",
  ustedes: "Ustedes",
  gastronomia: "Gastronomía",
};

// Estilos de grid por tamaño
const gridClasses: Record<string, string> = {
  grande: "sm:col-span-2 sm:row-span-2",
  ancho: "sm:col-span-2",
  alto: "sm:row-span-2",
  normal: "",
};

// Fotos a mostrar inicialmente y por cada "ver más"
const FOTOS_POR_PAGINA = 12;

// Color del overlay según categoría
const overlayColor: Record<string, string> = {
  arquitectura: "from-black/70",
  guaranies: "from-[#ABA30A]/90",
  cultura: "from-[#8C3B17]/80",
  gastronomia: "from-[#8C3B17]/80",
};
---

<Layout
  title="Galería de Fotos - La Aripuca | Selva Misionera"
  description="Galería fotográfica de La Aripuca en Puerto Iguazú. Imágenes de la selva misionera, cultura guaraní y los espacios únicos del complejo ecoturístico."
>
  <main>
    <!-- Hero -->
    <section class="relative w-full text-center">
      <!-- Mobile -->
      <div class="relative md:hidden">
        <img
          src="/images/aripuca-compromiso.jpeg"
          alt="Galería de La Aripuca"
          class="block h-[65vw] min-h-65 w-full object-cover"
        />
        <div class="absolute inset-0 bg-linear-to-b from-black/20 to-black/75">
        </div>
        <div
          class="absolute inset-0 flex flex-col items-center justify-end px-6 pb-8"
        >
          <span
            class="font-title mb-2 text-xs font-bold tracking-widest text-[#BFB065] uppercase drop-shadow-md"
          >
            Puerto Iguazú · Misiones
          </span>
          <h1
            class="font-title text-4xl font-black tracking-tight text-white drop-shadow-lg"
          >
            Nuestra Galería
          </h1>
          <p class="font-body mt-2 text-sm leading-snug text-white/80 italic">
            Selva, cultura y arquitectura en imágenes
          </p>
        </div>
      </div>

      <!-- Desktop -->
      <div
        class="hidden md:flex md:h-[85vh] md:w-full md:flex-col md:items-center md:justify-end md:bg-cover md:bg-center md:bg-no-repeat md:pb-24"
        style="background-image: linear-gradient(to bottom, rgba(0,0,0,0.15) 30%, rgba(0,0,0,0.75)), url('/images/aripuca-compromiso.jpeg');"
      >
        <div class="relative z-10 max-w-3xl px-6">
          <span
            class="font-title mb-4 inline-block text-xs font-bold tracking-widest text-[#BFB065] uppercase drop-shadow-md"
          >
            Puerto Iguazú · Misiones
          </span>
          <h1
            class="font-title mb-4 text-7xl font-black tracking-tight text-white drop-shadow-lg"
          >
            Nuestra Galería
          </h1>
          <p
            class="font-body mx-auto max-w-xl text-xl leading-relaxed text-white/80 italic"
          >
            Selva misionera, cultura guaraní y arquitectura única.<br />
            Viví La Aripuca antes de llegar.
          </p>
        </div>
      </div>
    </section>

    <!-- Category Filters -->
    <section
      class="sticky top-20 z-40 border-b border-stone-100 bg-white/90 py-4 shadow-sm backdrop-blur-md md:top-24"
    >
      <div class="no-scrollbar mx-auto max-w-7xl overflow-x-auto px-4">
        <div class="flex min-w-max justify-center gap-3" id="filtros">
          {
            categorias.map((cat) => (
              <button
                class="filtro-btn rounded-full border-2 px-6 py-2 text-xs font-bold tracking-widest uppercase transition-all duration-300"
                data-categoria={cat}
              >
                {categoriasLabel[cat]}
              </button>
            ))
          }
        </div>
      </div>
    </section>

    <script
      id="fotos-data"
      type="application/json"
      is:inline
      set:html={JSON.stringify(fotos)}
    />

    <!-- Dynamic Gallery Grid -->
    <section class="mx-auto max-w-7xl px-4 py-12 sm:px-8">
      <div
        class="grid auto-rows-[150px] grid-cols-1 gap-4 sm:auto-rows-[200px] sm:grid-cols-2 lg:grid-cols-4"
        id="galeria"
      >
        {
          fotos.map((foto, index) => (
            <div
              class:list={[
                "foto-item group relative cursor-pointer overflow-hidden rounded-xl bg-stone-100 transition-all duration-500",
                gridClasses[foto.tamaño],
                index >= FOTOS_POR_PAGINA ? "hidden" : "",
              ]}
              data-categoria={foto.categoria}
              data-index={index}
              data-paginated={index >= FOTOS_POR_PAGINA ? "hidden" : "visible"}
            >
              <img
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                alt={foto.alt}
                src={foto.src}
                loading="lazy"
              />
              <div
                class:list={[
                  "absolute inset-0 flex flex-col justify-end bg-linear-to-t via-transparent to-transparent p-4 opacity-0 transition-opacity duration-500 group-hover:opacity-100 sm:p-6",
                  overlayColor[foto.categoria],
                ]}
              >
                {foto.categoria && (
                  <span class="mb-1 text-xs font-bold tracking-widest text-[#BFB065] uppercase">
                    {categoriasLabel[foto.categoria]}
                  </span>
                )}
                <h3
                  class:list={[
                    "font-title text-white",
                    foto.tamaño === "grande"
                      ? "text-2xl"
                      : foto.tamaño === "ancho"
                        ? "text-xl"
                        : "text-sm",
                  ]}
                >
                  {foto.titulo}
                </h3>
                {foto.descripcion && (
                  <p class="font-body mt-1 text-sm text-white/80 italic">
                    {foto.descripcion}
                  </p>
                )}
              </div>
            </div>
          ))
        }
      </div>

      <!-- Ver Más -->
      <div class="mt-16 text-center" id="ver-mas-container">
        <button
          id="btn-ver-mas"
          class="inline-flex items-center gap-2 rounded-full border-2 border-[#ABA30A] px-10 py-4 font-bold text-[#ABA30A] transition-all hover:bg-[#ABA30A] hover:text-white"
        >
          VER MÁS FOTOS
          <span
            id="fotos-restantes"
            class="rounded-full bg-[#ABA30A]/10 px-3 py-0.5 text-sm"></span>
        </button>
      </div>
    </section>

    <!-- Lightbox -->
    <div
      id="lightbox"
      class="pointer-events-none fixed inset-0 z-50 flex items-center justify-center bg-black/90 opacity-0 backdrop-blur-sm transition-opacity duration-300"
    >
      <!-- Cerrar -->
      <button
        id="lightbox-cerrar"
        class="absolute top-5 right-5 z-10 flex h-12 w-12 items-center justify-center rounded-full bg-white/10 text-white backdrop-blur-md transition-all hover:scale-110 hover:bg-white/20"
        aria-label="Cerrar"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <!-- Anterior -->
      <button
        id="lightbox-prev"
        class="absolute left-3 z-10 flex h-12 w-12 items-center justify-center rounded-full bg-white/10 text-white backdrop-blur-md transition-all hover:scale-110 hover:bg-white/20 sm:left-6"
        aria-label="Anterior"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <!-- Siguiente -->
      <button
        id="lightbox-next"
        class="absolute right-3 z-10 flex h-12 w-12 items-center justify-center rounded-full bg-white/10 text-white backdrop-blur-md transition-all hover:scale-110 hover:bg-white/20 sm:right-6"
        aria-label="Siguiente"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path>
        </svg>
      </button>

      <!-- Imagen + Info -->
      <div class="flex max-h-[90vh] max-w-[90vw] flex-col items-center">
        <img
          id="lightbox-img"
          class="max-h-[75vh] max-w-full rounded-xl object-contain shadow-2xl transition-transform duration-300"
          src=""
          alt=""
        />
        <div class="mt-4 text-center">
          <h3 id="lightbox-titulo" class="font-title text-xl text-white"></h3>
          <p
            id="lightbox-desc"
            class="font-body mt-1 text-sm text-white/60 italic"
          >
          </p>
          <span
            id="lightbox-cat"
            class="mt-2 inline-block rounded-full bg-white/10 px-4 py-1 text-xs font-bold tracking-widest text-[#BFB065] uppercase"
          ></span>
        </div>
      </div>
    </div>

    <!-- CTA Banner -->
    <section class="bg-[#F2F2F2] px-4 py-20 sm:px-8">
      <div
        class="relative mx-auto max-w-6xl overflow-hidden rounded-3xl bg-[#8C3B17] p-10 text-white shadow-2xl md:p-16"
      >
        <div
          class="absolute top-0 right-0 -mt-20 -mr-20 h-64 w-64 rounded-full bg-[#ABA30A]/20 blur-3xl"
        >
        </div>
        <div class="relative z-10 grid items-center gap-12 md:grid-cols-2">
          <div>
            <h2 class="font-title mb-6 text-4xl leading-tight md:text-5xl">
              Vivilo en primera persona
            </h2>
            <p class="font-body text-lg leading-relaxed text-white/80 italic">
              Nada se compara con sentir el aroma del monte y la frescura de las
              maderas centenarias. Te esperamos para compartir el legado de la
              selva.
            </p>
          </div>
          <div class="flex justify-center md:justify-end">
            <button
              class="rounded-full bg-[#ABA30A] px-12 py-5 text-xl font-bold text-white shadow-xl transition-all hover:scale-105 hover:bg-[#BFB065] active:scale-95"
            >
              <a href="https://wa.me/5493757315512">Planificá tu visita</a>
            </button>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // ============ DATA ============
    const FOTOS_POR_PAGINA = 12;

    const fotosData = JSON.parse(
      document.getElementById("fotos-data")!.textContent!,
    );

    const categoriasLabel: Record<string, string> = {
      todo: "Todo",
      arquitectura: "Arquitectura",
      naturaleza: "Naturaleza",
      cultura: "Cultura",
      gastronomia: "Gastronomía",
    };

    // ============ ELEMENTS ============
    const filtros = document.querySelectorAll<HTMLButtonElement>(".filtro-btn");
    const items = document.querySelectorAll<HTMLElement>(".foto-item");
    const lightbox = document.getElementById("lightbox")!;
    const lbImg = document.getElementById("lightbox-img") as HTMLImageElement;
    const lbTitulo = document.getElementById("lightbox-titulo")!;
    const lbDesc = document.getElementById("lightbox-desc")!;
    const lbCat = document.getElementById("lightbox-cat")!;
    const btnCerrar = document.getElementById("lightbox-cerrar")!;
    const btnPrev = document.getElementById("lightbox-prev")!;
    const btnNext = document.getElementById("lightbox-next")!;
    const btnVerMas = document.getElementById("btn-ver-mas")!;
    const verMasContainer = document.getElementById("ver-mas-container")!;
    const fotosRestantesSpan = document.getElementById("fotos-restantes")!;

    let categoriaActual = "todo";
    let indiceActual = 0;
    let fotosVisibles = FOTOS_POR_PAGINA;

    // ============ PAGINACIÓN ============
    function getItemsFiltrados(): HTMLElement[] {
      return Array.from(items).filter((item) => {
        const cat = item.dataset.categoria;
        return categoriaActual === "todo" || cat === categoriaActual;
      });
    }

    function actualizarPaginacion() {
      const filtrados = getItemsFiltrados();
      const total = filtrados.length;
      const restantes = Math.max(0, total - fotosVisibles);

      // Mostrar/ocultar cada item
      items.forEach((item) => {
        const cat = item.dataset.categoria;
        const coincideFiltro =
          categoriaActual === "todo" || cat === categoriaActual;

        if (!coincideFiltro) {
          // No coincide con el filtro: ocultar
          item.style.opacity = "0";
          item.style.transform = "scale(0.95)";
          setTimeout(() => {
            item.classList.add("hidden");
            item.style.display = "";
          }, 300);
        } else {
          // Coincide con el filtro: verificar paginación
          const indexEnFiltrados = filtrados.indexOf(item);

          if (indexEnFiltrados < fotosVisibles) {
            // Dentro del límite: mostrar
            item.classList.remove("hidden");
            item.style.opacity = "0";
            item.style.transform = "scale(0.95)";
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                item.style.opacity = "1";
                item.style.transform = "scale(1)";
              });
            });
          } else {
            // Fuera del límite: ocultar
            item.classList.add("hidden");
          }
        }
      });

      // Actualizar botón "Ver más"
      if (restantes > 0) {
        verMasContainer.classList.remove("hidden");
        fotosRestantesSpan.textContent = `+${restantes}`;
      } else {
        verMasContainer.classList.add("hidden");
      }
    }

    // ============ FILTROS ============
    function actualizarFiltroActivo() {
      filtros.forEach((btn) => {
        const cat = btn.dataset.categoria;
        if (cat === categoriaActual) {
          btn.classList.add(
            "bg-[#8C3B17]",
            "text-white",
            "border-[#8C3B17]",
            "shadow-lg",
          );
          btn.classList.remove("border-stone-100", "text-stone-600");
        } else {
          btn.classList.remove(
            "bg-[#8C3B17]",
            "text-white",
            "border-[#8C3B17]",
            "shadow-lg",
          );
          btn.classList.add("border-stone-100", "text-stone-600");
        }
      });
    }

    filtros.forEach((btn) => {
      btn.addEventListener("click", () => {
        categoriaActual = btn.dataset.categoria || "todo";
        fotosVisibles = FOTOS_POR_PAGINA; // Resetear paginación al cambiar filtro
        actualizarFiltroActivo();
        actualizarPaginacion();
      });
    });

    // Botón "Ver más"
    btnVerMas.addEventListener("click", () => {
      fotosVisibles += FOTOS_POR_PAGINA;
      actualizarPaginacion();
    });

    // Estado inicial
    actualizarFiltroActivo();
    actualizarPaginacion();

    // ============ LIGHTBOX ============
    function getItemsMostrados(): HTMLElement[] {
      return Array.from(items).filter((i) => !i.classList.contains("hidden"));
    }

    function abrirLightbox(index: number) {
      const visibles = getItemsMostrados();
      indiceActual = index;
      const item = visibles[indiceActual];
      if (!item) return;

      const img = item.querySelector("img")!;
      const idx = parseInt(item.dataset.index || "0");
      const data = fotosData[idx];

      lbImg.src = img.src;
      lbImg.alt = img.alt;
      lbTitulo.textContent = data.titulo;
      lbDesc.textContent = data.descripcion;
      lbCat.textContent = categoriasLabel[data.categoria] || data.categoria;

      lightbox.classList.remove("opacity-0", "pointer-events-none");
      lightbox.classList.add("opacity-100", "pointer-events-auto");
      document.body.style.overflow = "hidden";
    }

    function cerrarLightbox() {
      lightbox.classList.add("opacity-0", "pointer-events-none");
      lightbox.classList.remove("opacity-100", "pointer-events-auto");
      document.body.style.overflow = "";
    }

    function navegarLightbox(dir: number) {
      const visibles = getItemsMostrados();
      indiceActual = (indiceActual + dir + visibles.length) % visibles.length;
      const item = visibles[indiceActual];
      const img = item.querySelector("img")!;
      const idx = parseInt(item.dataset.index || "0");
      const data = fotosData[idx];

      // Transición suave
      lbImg.style.opacity = "0";
      lbImg.style.transform =
        dir > 0 ? "translateX(40px)" : "translateX(-40px)";

      setTimeout(() => {
        lbImg.src = img.src;
        lbImg.alt = img.alt;
        lbTitulo.textContent = data.titulo;
        lbDesc.textContent = data.descripcion;
        lbCat.textContent = categoriasLabel[data.categoria] || data.categoria;
        lbImg.style.transform =
          dir > 0 ? "translateX(-40px)" : "translateX(40px)";

        requestAnimationFrame(() => {
          lbImg.style.opacity = "1";
          lbImg.style.transform = "translateX(0)";
        });
      }, 200);
    }

    // Click en fotos
    items.forEach((item) => {
      item.addEventListener("click", () => {
        const visibles = getItemsMostrados();
        const idx = visibles.indexOf(item);
        if (idx !== -1) abrirLightbox(idx);
      });
    });

    // Botones lightbox
    btnCerrar.addEventListener("click", cerrarLightbox);
    btnPrev.addEventListener("click", () => navegarLightbox(-1));
    btnNext.addEventListener("click", () => navegarLightbox(1));

    // Cerrar con fondo
    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) cerrarLightbox();
    });

    // Teclado
    document.addEventListener("keydown", (e) => {
      if (lightbox.classList.contains("pointer-events-none")) return;
      if (e.key === "Escape") cerrarLightbox();
      if (e.key === "ArrowLeft") navegarLightbox(-1);
      if (e.key === "ArrowRight") navegarLightbox(1);
    });
  });
</script>

