  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .foto-item {
    transition:
      opacity 0.4s ease,
      transform 0.4s ease;
  }
  #lightbox-img {
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }
</style>
