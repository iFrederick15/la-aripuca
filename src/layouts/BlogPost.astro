---
import Layout from "./Layout.astro";
import Header from "../components/globals/header.astro";
import Footer from "../components/globals/footer.astro";

interface Props {
  title: string;
  pageTitle: string;
  category: string;
  date: string;
  dateLabel: string;
  readTime: string;
  image: string;
  imageAlt: string;
}

const {
  title,
  pageTitle,
  category,
  date,
  dateLabel,
  readTime,
  image,
  imageAlt,
} = Astro.props;
---

<Layout title={pageTitle}>
  <Header />

  <section class="post-hero">
    <div class="container">
      <span class="post-category-badge">{category}</span>
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={date}>{dateLabel}</time>
        <span class="separator">•</span>
        <span>{readTime}</span>
      </div>
    </div>
  </section>

  <main class="blog-section">
    <div class="container-narrow">
      <img src={image} alt={imageAlt} class="post-image" />

      <article class="post-content">
        <slot />
      </article>

      <a href="/blog" class="back-link">← Volver al Blog</a>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .post-hero {
    background: linear-gradient(135deg, var(--color-primario) 0%, #6b2d12 100%);
    color: white;
    padding: 6rem 0 3rem;
    text-align: center;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .container-narrow {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .post-category-badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.2);
    color: white;
    padding: 0.35rem 1rem;
    border-radius: 20px;
    font-family: var(--font-titulo);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 1rem;
  }

  .post-hero h1 {
    font-family: var(--font-titulo);
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 1rem 0;
    line-height: 1.2;
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: "Lucida Serif", serif;
    font-size: 0.9rem;
    opacity: 0.85;
  }

  .separator {
    color: var(--color-secundario);
  }

  .blog-section {
    padding: 3rem 0 5rem;
    background-color: var(--color-fondo);
  }

  .post-image {
    width: 100%;
    height: 22rem;
    object-fit: cover;
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    margin-bottom: 2.5rem;
  }

  @media (max-width: 640px) {
    .post-image {
      height: 14rem;
    }
  }

  /* Estilos para el contenido Markdown */
  .post-content {
    font-family: "Lucida Serif", serif;
    font-size: 1.1rem;
    line-height: 1.85;
    color: #3a3a3a;
  }

  /* IMPORTANTE: Párrafos con espaciado */
  .post-content :global(p) {
    margin-bottom: 2rem;
    margin-top: 0;
  }

  .post-content :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Negritas */
  .post-content :global(strong),
  .post-content :global(b) {
    font-weight: 700;
    color: #2c2c2c;
  }

  /* Cursivas */
  .post-content :global(em),
  .post-content :global(i) {
    font-style: italic;
  }

  /* Headings */
  .post-content :global(h2) {
    font-family: var(--font-titulo);
    font-size: 1.75rem;
    margin: 2.5rem 0 1.25rem 0;
    color: var(--color-primario);
  }

  .post-content :global(h3) {
    font-family: var(--font-titulo);
    font-size: 1.4rem;
    margin: 2rem 0 1rem 0;
    color: #2c2c2c;
  }

  /* Listas */
  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 1.5rem 0;
    padding-left: 2rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.75rem;
  }

  /* Links */
  .post-content :global(a) {
    color: var(--color-primario);
    text-decoration: underline;
    transition: color 0.2s;
  }

  .post-content :global(a:hover) {
    color: var(--color-secundario);
  }

  /* Blockquotes */
  .post-content :global(blockquote) {
    border-left: 4px solid var(--color-primario);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: #666;
  }

  .back-link {
    display: inline-block;
    margin-top: 2.5rem;
    font-family: var(--font-titulo);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-primario);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s;
  }

  .back-link:hover {
    border-color: var(--color-primario);
  }
</style>
