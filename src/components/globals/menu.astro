<div class="flex items-center">
  <!-- Botón hamburguesa (solo visible en mobile) -->
  <button
    id="menu-toggle"
    class="block text-[#8a320d] focus:outline-none lg:hidden"
    aria-label="Abrir menú"
  >
    <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
  </button>

  <!-- Menú desktop y mobile -->
  <nav class="font-title text-primario font-bold">
    <ul
      id="menu"
      class="bg-fondo fixed top-18 right-0 hidden w-full flex-col gap-4 px-6 py-6 shadow-lg backdrop-blur-md lg:static lg:flex lg:w-auto lg:flex-row lg:gap-10 lg:bg-transparent lg:p-0 lg:shadow-none lg:backdrop-blur-none"
    >
      <li>
        <a href="/" class="block py-2 pb-1 hover:border-b-2 lg:py-0">Inicio</a>
      </li>

      <!-- Menú con dropdown -->
      <li class="group relative">
        <button
          class="flex w-full items-center justify-between gap-1 pb-1 text-left hover:border-b-2 hover:text-[#8a320d] lg:w-auto lg:justify-center lg:text-center"
          data-dropdown-toggle
        >
          Espacios
          <svg
            class="dropdown-arrow h-3 w-3 transition-transform group-hover:rotate-180"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>

        <!-- Submenu -->
        <ul
          class="dropdown-menu lg:ring-opacity-5 lg:bg-fondo hidden lg:absolute lg:top-full lg:left-0 lg:mt-2 lg:w-48 lg:rounded-lg lg:shadow-lg lg:ring-1 lg:ring-black lg:backdrop-blur-md"
        >
          <div>
            <li>
              <a
                href="/#lastacuaras"
                class="block px-4 py-3 transition hover:text-[#8a320d]"
              >
                Las Tacuaras
              </a>
            </li>
            <li>
              <a
                href="/#losguaranies"
                class="block px-4 py-3 transition hover:text-[#8a320d]"
              >
                Los Guaraníes
              </a>
            </li>
            <li>
              <a
                href="/#eltacuru"
                class="block px-4 py-3 transition hover:text-[#8a320d]"
              >
                El Tacurú
              </a>
            </li>
            <li>
              <a
                href="/#elyatei"
                class="block px-4 py-3 transition hover:text-[#8a320d]"
              >
                El Yateí
              </a>
            </li>
            <li>
              <a
                href="/#elcucurucho"
                class="block px-4 py-3 transition hover:text-[#8a320d]"
              >
                El Cucurucho
              </a>
            </li>
            <li>
              <a
                href="/#lastermitas"
                class="block px-4 py-3 transition hover:text-[#8a320d]"
              >
                Las Termitas
              </a>
            </li>
          </div>
        </ul>
      </li>

      <li>
        <a
          href="/galeria"
          class="block py-2 pb-1 hover:border-b-2 hover:text-[#8a320d] lg:py-0"
          >Galería</a
        >
      </li>
      <li>
        <a
          href="/blog"
          class="block py-2 pb-1 hover:border-b-2 hover:text-[#8a320d] lg:py-0"
          >Blog</a
        >
      </li>
    </ul>
  </nav>
</div>

<style>
  @reference "tailwindcss";
  a,
  button {
    @apply font-medium transition duration-300 hover:text-[#8a320d];
  }

  /* Desktop: hover para mostrar dropdown */
  @media (min-width: 1024px) {
    .group:hover ul {
      display: block;
    }

    .dropdown-menu {
      background-color: rgb(255 255 255 / 0.9);
      backdrop-filter: blur(12px);
      box-shadow:
        0 10px 15px -3px rgb(0 0 0 / 0.1),
        0 4px 6px -4px rgb(0 0 0 / 0.1);
    }
  }

  /* Mobile: menú abierto */
  #menu.open {
    display: flex;
  }

  /* Mobile: dropdown abierto */
  .dropdown-menu.open {
    display: block;
  }

  /* Rotación de flecha cuando dropdown está abierto */
  .dropdown-arrow.open {
    transform: rotate(180deg);
  }
</style>

<script>
  // Toggle menú hamburguesa
  const menuToggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("menu");

  menuToggle?.addEventListener("click", () => {
    menu?.classList.toggle("open");
  });

  // Toggle dropdown en mobile
  const dropdownToggles = document.querySelectorAll("[data-dropdown-toggle]");

  dropdownToggles.forEach((toggle) => {
    toggle.addEventListener("click", (e) => {
      // Solo en mobile
      if (window.innerWidth < 1024) {
        e.preventDefault();
        const dropdown = toggle.nextElementSibling;
        const arrow = toggle.querySelector(".dropdown-arrow");

        dropdown?.classList.toggle("open");
        arrow?.classList.toggle("open");
      }
    });
  });

  // Cerrar menú al hacer click en un link (mobile)
  const menuLinks = menu?.querySelectorAll("a");
  menuLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      if (window.innerWidth < 1024) {
        menu?.classList.remove("open");
      }
    });
  });
</script>
