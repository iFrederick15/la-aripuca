<div class="flex items-center">
  <!-- Botón hamburguesa (solo visible en mobile) -->
  <button
    id="menu-toggle"
    class="z-50 flex flex-col gap-1.5 p-1 lg:hidden"
    aria-label="Abrir menú"
    aria-expanded="false"
  >
    <span
      class="bar bg-primary block h-0.5 w-6 origin-center transition-all duration-300"
    ></span>
    <span class="bar bg-primary block h-0.5 w-6 transition-all duration-300"
    ></span>
    <span
      class="bar bg-primary block h-0.5 w-6 origin-center transition-all duration-300"
    ></span>
  </button>

  <!-- Menú desktop y mobile -->
  <nav class="font-title text-primary font-bold">
    <ul
      id="menu"
      class="bg-fondo fixed top-18 right-0 hidden w-full flex-col gap-4 px-6 py-6 shadow-lg backdrop-blur-md lg:static lg:flex lg:w-auto lg:flex-row lg:gap-10 lg:bg-transparent lg:p-0 lg:shadow-none lg:backdrop-blur-none"
    >
      <li>
        <a href="/" class="nav-link block py-2 pb-1 lg:py-0">Inicio</a>
      </li>

      <!-- Menú con dropdown -->
      <li class="group relative">
        <button
          class="nav-link flex w-full items-center justify-between gap-1 pb-1 text-left lg:w-auto lg:justify-center lg:text-center"
          data-dropdown-toggle
        >
          Espacios
          <svg
            class="dropdown-arrow h-3 w-3 transition-transform group-hover:rotate-180"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>

        <!-- Submenu -->
        <ul class="dropdown-menu hidden">
          <li>
            <a href="/#lastacuaras" class="dropdown-link block px-4 py-2.5"
              >Las Tacuaras</a>
          </li>
          <li>
            <a href="/#losguaranies" class="dropdown-link block px-4 py-2.5"
              >Los Guaraníes</a>
          </li>
          <li>
            <a href="/#eltacuru" class="dropdown-link block px-4 py-2.5"
              >El Tacurú</a>
          </li>
          <li>
            <a href="/#elyatei" class="dropdown-link block px-4 py-2.5"
              >El Yateí</a>
          </li>
          <li>
            <a href="/#elcucurucho" class="dropdown-link block px-4 py-2.5"
              >El Cucurucho</a>
          </li>
          <li>
            <a href="/#lastermitas" class="dropdown-link block px-4 py-2.5"
              >Las Termitas</a>
          </li>
        </ul>
      </li>

      <li>
        <a href="/galeria" class="nav-link block py-2 pb-1 lg:py-0">Galería</a>
      </li>
      <li>
        <a href="/blog" class="nav-link block py-2 pb-1 lg:py-0">Blog</a>
      </li>
      <li class="lg:hidden">
        <a href="/#contacto" class="buttonHeader mt-2 inline-block">Contacto</a>
      </li>
    </ul>
  </nav>
</div>

<style>
  /* Nav links — subrayado animado en desktop */
  .nav-link {
    position: relative;
    font-weight: 600;
    color: var(--color-primary);
    transition: color 0.2s ease;
  }
  .nav-link:hover {
    color: var(--color-secondary);
  }
  @media (min-width: 1024px) {
    .nav-link::after {
      content: "";
      position: absolute;
      bottom: -3px;
      left: 0;
      width: 0;
      height: 2px;
      background-color: var(--color-secondary);
      transition: width 0.25s ease;
    }
    .nav-link:hover::after {
      width: 100%;
    }
  }

  /* Dropdown links */
  .dropdown-link {
    font-size: 0.875rem;
    color: var(--color-primary);
    transition:
      color 0.2s ease,
      padding-left 0.2s ease;
  }
  .dropdown-link:hover {
    color: var(--color-secondary);
    padding-left: 1.25rem;
  }

  /* Dropdown desktop */
  @media (min-width: 1024px) {
    .group:hover .dropdown-menu {
      display: block;
      animation: dropDown 0.18s ease forwards;
    }
    .dropdown-menu {
      position: absolute;
      top: calc(100% + 10px);
      left: 50%;
      transform: translateX(-50%);
      min-width: 210px;
      padding: 0.375rem 0;
      background-color: white;
      border-radius: 0.75rem;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
      border: 1px solid rgba(140, 59, 23, 0.1);
    }
    /* Puente invisible que cubre el gap para que no se pierda el hover */
    .dropdown-menu::before {
      content: "";
      position: absolute;
      top: -10px;
      left: 0;
      right: 0;
      height: 10px;
    }
    .dropdown-menu li:not(:last-child) {
      border-bottom: 1px solid rgba(140, 59, 23, 0.06);
    }
  }

  /* Mobile: menú abierto */
  #menu.open {
    display: flex;
    animation: slideDown 0.2s ease forwards;
  }

  /* Mobile: dropdown abierto */
  .dropdown-menu.open {
    display: block;
  }

  /* Hamburger → X */
  #menu-toggle.open .bar:nth-child(1) {
    transform: rotate(45deg) translate(3px, 3px);
  }
  #menu-toggle.open .bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #menu-toggle.open .bar:nth-child(3) {
    transform: rotate(-45deg) translate(3px, -3px);
  }

  /* Flecha dropdown en mobile */
  .dropdown-arrow.open {
    transform: rotate(180deg);
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes dropDown {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }
</style>

<script>
  const menuToggle = document.getElementById(
    "menu-toggle",
  ) as HTMLButtonElement | null;
  const menu = document.getElementById("menu");

  menuToggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("open");
    menuToggle.classList.toggle("open", isOpen);
    menuToggle.setAttribute("aria-expanded", String(isOpen));
  });

  document.querySelectorAll("[data-dropdown-toggle]").forEach((toggle) => {
    toggle.addEventListener("click", (e) => {
      if (window.innerWidth < 1024) {
        e.preventDefault();
        const dropdown = toggle.nextElementSibling;
        const arrow = toggle.querySelector(".dropdown-arrow");
        dropdown?.classList.toggle("open");
        arrow?.classList.toggle("open");
      }
    });
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      if (window.innerWidth < 1024) {
        menu.classList.remove("open");
        menuToggle?.classList.remove("open");
        menuToggle?.setAttribute("aria-expanded", "false");
      }
    });
  });
</script>
