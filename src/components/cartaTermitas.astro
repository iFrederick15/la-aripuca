    const numero = parseFloat(
      precioARS.replace("$", "").replaceAll(".", "").replace(",", "."),
    );
    if (lang === "en") return "US$ " + (numero / USD).toFixed(2);
    if (lang === "pt") return "R$ " + (numero / BRL).toFixed(2).replace(".", ",");
    return precioARS;
  }

