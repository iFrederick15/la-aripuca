  function render(lang: string) {
    const menuEs = document.getElementById("menu-es")!;
    const menuDynamic = document.getElementById("menu-container")!;
    const footerEs = document.getElementById("carta-footer-es")!;
    const footerDynamic = document.getElementById("carta-footer")!;

    if (lang === "es") {
      menuEs.classList.remove("hidden");
      menuEs.style.display = "flex";
      menuDynamic.classList.add("hidden");
      footerEs.classList.remove("hidden");
      footerDynamic.classList.add("hidden");
      return;
    }

    menuEs.classList.add("hidden");
    menuDynamic.classList.remove("hidden");
    menuDynamic.style.display = "flex";
    footerEs.classList.add("hidden");
    footerDynamic.classList.remove("hidden");

    const d = menu[lang];

    footerDynamic.innerHTML = d.footer
      .map((f) => `<p class="footer-texto">${f}</p>`)
      .join("");

    menuDynamic.innerHTML = d.categorias
      .map(
        (cat, i) => `
        <div class="categoria" style="animation-delay:${i * 0.05}s">
          <div class="cat-header">
            <span class="cat-icono">${cat.icono}</span>
            <h2 class="cat-nombre">${cat.nombre}</h2>
            <div class="cat-linea"></div>
          </div>
          ${cat.nota ? `<p class="cat-nota">★ ${cat.nota}</p>` : ""}
          <div>
            ${cat.items
              .map(
                (item: any) => `
              <div class="item">
                <div>
                  <p class="item-nombre">${item.nombre}</p>
                  ${item.descripcion ? `<p class="item-desc">${item.descripcion}</p>` : ""}
                </div>
                <span class="item-precio">${convertirPrecio(item.precio, lang)}</span>
              </div>
            `,
              )
              .join("")}
          </div>
        </div>
      `,
      )
      .join("");
  }

  document.querySelectorAll(".lang-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      document
        .querySelectorAll(".lang-btn")
        .forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      render((btn as HTMLElement).dataset.lang!);
    });
  });
