      viewBox="0 0 200 250"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M100 5 C60 30 10 80 10 140 C10 190 50 245 100 245 C150 245 190 190 190 140 C190 80 140 30 100 5Z"
