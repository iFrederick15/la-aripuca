    <button
      class="lang-btn active font-title text-primary border-primary hover:bg-primary rounded-xl border px-4 py-1.5 text-sm transition-all duration-200 hover:text-white"
      data-lang="es">🇦🇷 Español</button
    >
    <button
      class="lang-btn font-title hover:bg-primary text-primary border-primary rounded-xl border px-4 py-1.5 text-sm transition-all duration-200 hover:text-white"
      data-lang="en">🇺🇸 English</button
    >
    <button
      class="lang-btn font-title border-primary text-primary hover:bg-primary rounded-xl border px-4 py-1.5 text-sm transition-all duration-200 hover:text-white"
      data-lang="pt">🇧🇷 Português</button
    >
  </div>

  <!-- Encabezado -->
  <div class="mb-10 text-center">
    <h1 class="font-title text-primary mb-1 text-5xl leading-tight font-bold">
      Las Termitas
    </h1>
    <p class="font-title text-secondary mb-4 text-xs tracking-[0.25em] uppercase">
      Restaurante
    </p>
    <div
      class="via-secondary mx-auto h-0.5 w-16 bg-linear-to-r from-transparent to-transparent"
    >
    </div>
  </div>

  <!-- Menú español (renderizado en servidor — indexable por Google) -->
  <div id="menu-es" class="mx-auto flex max-w-3xl flex-col gap-8">
    {menuEs.map((cat, i) => (
      <div class="categoria" style={`animation-delay:${i * 0.05}s`}>
        <div class="cat-header">
          <span class="cat-icono">{cat.icono}</span>
          <h2 class="cat-nombre">{cat.nombre}</h2>
          <div class="cat-linea"></div>
        </div>
        {cat.nota && <p class="cat-nota">★ {cat.nota}</p>}
        <div>
          {cat.items.map((item) => (
            <div class="item">
              <div>
                <p class="item-nombre">{item.nombre}</p>
                {item.descripcion && <p class="item-desc">{item.descripcion}</p>}
              </div>
              <span class="item-precio">{item.precio}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- Contenedor dinámico para EN/PT (oculto hasta que el usuario cambie idioma) -->
  <div id="menu-container" class="mx-auto hidden max-w-3xl flex-col gap-8"></div>

  <!-- Footer español (renderizado en servidor) -->
  <div
    id="carta-footer-es"
    class="border-primary/20 mx-auto mt-10 max-w-3xl border-t pt-5 text-center"
  >
    {footerEs.map((f) => <p class="footer-texto">{f}</p>)}
  </div>

  <!-- Footer dinámico para EN/PT -->
  <div
    id="carta-footer"
    class="border-primary/20 mx-auto mt-10 hidden max-w-3xl border-t pt-5 text-center"
  >
  </div>
</section>

<style>
  .lang-btn.active {
    background-color: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  :global(.categoria) {
    animation: fadeUp 0.4s ease both;
  }
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  :global(.cat-header) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  :global(.cat-icono) {
    font-size: 1.25rem;
  }
  :global(.cat-nombre) {
    font-family: var(--font-title);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
  }
  :global(.cat-linea) {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to right,
      color-mix(in srgb, var(--color-primary) 30%, transparent),
      transparent
    );
  }
  :global(.cat-nota) {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-style: italic;
    color: color-mix(in srgb, var(--color-primary) 60%, transparent);
    margin-bottom: 0.75rem;
    padding-left: 0.25rem;
  }

  :global(.item) {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.75rem;
    align-items: baseline;
    padding: 0.75rem 0;
    border-bottom: 1px dashed
      color-mix(in srgb, var(--color-primary) 15%, transparent);
    transition: all 0.2s;
  }
  :global(.item:last-child) {
    border-bottom: none;
  }
  :global(.item:hover) {
    background: color-mix(in srgb, var(--color-secondary) 5%, transparent);
    border-radius: 0.375rem;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
  }
  :global(.item-nombre) {
    font-family: var(--font-title);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
  }
  :global(.item-desc) {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: color-mix(in srgb, var(--color-primary) 60%, transparent);
    margin-top: 0.125rem;
    line-height: 1.5;
  }
  :global(.item-precio) {
    font-family: var(--font-title);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-secondary);
    white-space: nowrap;
  }
  :global(.footer-texto) {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-style: italic;
    color: color-mix(in srgb, var(--color-primary) 60%, transparent);
    line-height: 1.8;
  }
</style>

