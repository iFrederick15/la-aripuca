          <path
            d="M 42 35 Q 30 20 25 5"
            stroke="currentColor"
            stroke-width="2.5"
            fill="none"
            stroke-linecap="round"></path>
          <path
            d="M 58 35 Q 70 20 75 5"
            stroke="currentColor"
            stroke-width="2.5"
            fill="none"
            stroke-linecap="round"></path>

          <!-- Patas delgadas (solo 3 pares visibles) -->
          <!-- Par 1 -->
          <path
            d="M 35 80 Q 20 85 15 95"
