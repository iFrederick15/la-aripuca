<section class="bg-fondo px-4 py-24 sm:px-6" id="contacto">
  <div
    class="mx-auto grid max-w-7xl overflow-hidden rounded-4xl bg-white shadow md:grid-cols-2"
  >
    <div class="p-6 sm:p-10 md:p-16">
      <h2 class="text-on-background font-title mb-8 text-4xl">
        Conectá con nosotros
      </h2>
      <div class="space-y-6">
        <div class="grid gap-6 md:grid-cols-2">
          <div>
            <label class="text-on-surface mb-2 block text-sm font-bold"
              >Nombre</label
            >
            <input
              id="nombre"
              class="bg-secundario/20 focus:ring-primary-container w-full rounded-xl border-none p-2 transition-all focus:ring-2"
              placeholder="Tu nombre"
              type="text"
            />
          </div>
          <div>
            <label class="text-on-surface mb-2 block text-sm font-bold"
              >Email</label
            >
            <input
              id="email"
              class="bg-secundario/20 focus:ring-primary-container w-full rounded-xl border-none p-2 transition-all focus:ring-2"
              placeholder="hola@ejemplo.com"
              type="email"
            />
          </div>
        </div>
        <div>
          <label class="text-on-surface mb-2 block text-sm font-bold"
            >Mensaje</label
          >
          <textarea
            id="mensaje"
            class="bg-secundario/20 focus:ring-primary-container w-full rounded-xl border-none p-2 transition-all focus:ring-2"
            placeholder="¿En qué podemos ayudarte?"
            rows="4"></textarea>
        </div>
        <button
          id="btn-enviar"
          class="bg-secundario w-full rounded-xl py-4 text-lg font-black text-white transition-opacity hover:opacity-95"
          >Enviar Mensaje</button
        >
      </div>
    </div>
    <div class="relative h-full min-h-64 md:min-h-100">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d17413.881170960358!2d-54.56750227813011!3d-25.60734294728779!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94f6923af74e96dd%3A0x131176475a377b6c!2sLa%20Aripuca!5e0!3m2!1ses!2sar!4v1775148706489!5m2!1ses!2sar"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        class="pointer-events-auto absolute inset-0 h-full w-full"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
      <div
        class="bg-secondary/10 pointer-events-none absolute inset-0 flex items-center justify-center"
      >
        <div class="flex items-center gap-4 rounded-2xl bg-white p-6 shadow-xl">
          <div>
            <p class="text-on-surface font-bold">Estamos aquí</p>
            <p class="text-on-surface-variant text-xs">
              Ruta 12, Km 4.5, Puerto Iguazú, Misiones, Argentina.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById("btn-enviar");

  btn?.addEventListener("click", () => {
    const nombre = (
      document.getElementById("nombre") as HTMLInputElement
    ).value.trim();
    const email = (
      document.getElementById("email") as HTMLInputElement
    ).value.trim();
    const mensaje = (
      document.getElementById("mensaje") as HTMLTextAreaElement
    ).value.trim();

    if (!nombre || !mensaje) {
      alert("Por favor completá tu nombre y mensaje.");
      return;
    }

    const texto = `Hola! Me contacto desde la web.
*Nombre:* ${nombre}
*Email:* ${email}
*Mensaje:* ${mensaje}`;

    const numero = "5493757315512";
    const url = `https://wa.me/${numero}?text=${encodeURIComponent(texto)}`;

    window.open(url, "_blank");
  });
</script>
